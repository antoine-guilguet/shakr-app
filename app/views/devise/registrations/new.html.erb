<section class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Create your Shakr account</h1>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-grid">
        <div class="auth-field">
          <%= f.label :first_name, class: "auth-label" %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= f.label :last_name, class: "auth-label" %>
          <%= f.text_field :last_name, autocomplete: "family-name", class: "auth-input" %>
        </div>
      </div>

      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <div class="auth-label-row">
          <%= f.label :password, class: "auth-label" %>
        </div>
        <%= f.password_field :password, autocomplete: "new-password", class: "auth-input" %>
        <% if @minimum_password_length %>
          <p class="auth-help">
            <%= @minimum_password_length %> characters minimum
          </p>
        <% end %>
      </div>

      <div class="auth-actions">
        <%= f.submit "Create account", class: "auth-button" %>
      </div>
    <% end %>

    <p class="auth-footer">
      Already shaking with us?
      <%= link_to "Log in", new_session_path(resource_name), class: "auth-link" %>
    </p>
  </div>
</section>
