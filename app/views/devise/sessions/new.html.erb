<section class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Welcome back to Shakr</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <div class="auth-label-row">
          <%= f.label :password, class: "auth-label" %>
          <%= link_to "Forgot?", new_password_path(resource_name), class: "auth-inline-link" %>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", class: "auth-input" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="auth-field auth-remember">
          <label class="auth-remember-label">
            <%= f.check_box :remember_me %>
            <span>Remember me on this device</span>
          </label>
        </div>
      <% end %>

      <div class="auth-actions">
        <%= f.submit "Log in", class: "auth-button" %>
      </div>
    <% end %>

    <p class="auth-footer">
      New here?
      <%= link_to "Create your account", new_registration_path(resource_name), class: "auth-link" %>
    </p>
  </div>
</section>
