<div class="recipes-ai-result-card<%= " recipes-show--voice-fab" if user_signed_in? %>">
  <div class="ai-recipe">
    <div class="ai-recipe-header">
      <h2 class="ai-recipe-title"><%= @recipe.name.presence || "Untitled Cocktail" %></h2>

      <% if @recipe.description.present? %>
        <p class="ai-recipe-description"><%= @recipe.description %></p>
      <% end %>

      <% if @recipe.tags.present? %>
        <div class="ai-recipe-tags">
          <% Array(@recipe.tags).each do |tag| %>
            <span class="ai-recipe-tag"><%= tag %></span>
          <% end %>
        </div>
      <% end %>

      <% if user_signed_in? && @recipe.user_id == current_user.id %>
        <div class="recipes-show-actions">
          <%= link_to "Edit", edit_recipe_path(@recipe), class: "btn-secondary hidden sm:inline-flex" %>
          <%= link_to "Delete",
            recipe_path(@recipe),
            method: :delete,
            data: {
              turbo_method: :delete,
              turbo_confirm: "Are you sure you want to delete this recipe?"
            },
            class: "btn-secondary hidden recipes-action-danger" %>
        </div>
      <% end %>
    </div>

    <div class="ai-recipe-body ai-recipe-body--desktop">
      <%= render "show_ingredients_section", recipe: @recipe %>
      <%= render "show_method_section", recipe: @recipe %>
    </div>

    <div
      class="ai-recipe-body ai-recipe-body--mobile-slider"
      data-controller="recipe-detail-slider"
    >
      <div class="voice-recipe-card voice-recipe-card--fancy recipe-show-slider-card">
        <div class="voice-recipe-card__slider">
          <div
            class="voice-recipe-card__track"
            data-recipe-detail-slider-target="track"
          >
            <div class="voice-recipe-card__slide">
              <div class="voice-recipe-card__slide-inner">
                <%= render "show_ingredients_section",
                           recipe: @recipe,
                           section_class: "ai-recipe-section ai-recipe-section--in-slider" %>
              </div>
            </div>
            <div class="voice-recipe-card__slide">
              <div class="voice-recipe-card__slide-inner">
                <%= render "show_method_section",
                           recipe: @recipe,
                           section_class: "ai-recipe-section ai-recipe-section--in-slider" %>
              </div>
            </div>
          </div>
        </div>
        <div class="voice-recipe-card__slider-controls">
          <button
            type="button"
            class="voice-recipe-card__slider-btn"
            data-recipe-detail-slider-target="prevButton"
            data-action="click->recipe-detail-slider#prev"
            aria-label="Previous section"
          >
            Prev
          </button>
          <span
            class="voice-recipe-card__slider-indicator"
            data-recipe-detail-slider-target="indicator"
            aria-live="polite"
          >
            1 / 2
          </span>
          <button
            type="button"
            class="voice-recipe-card__slider-btn"
            data-recipe-detail-slider-target="nextButton"
            data-action="click->recipe-detail-slider#next"
            aria-label="Next section"
          >
            Next
          </button>
        </div>
      </div>
    </div>
  </div>

  <% if user_signed_in? %>
    <%= render "shared/voice_agent_fab", mode: :link %>
  <% end %>
</div>
