<div class="voice-lab voice-lab--voice-fab">
  <section
    class="voice-lab-panel"
    data-controller="realtime-voice"
    data-realtime-voice-session-url-value="<%= realtime_sessions_path %>"
    data-realtime-voice-autostart-value="<%= @voice_autostart ? "true" : "false" %>"
    aria-label="Realtime voice session"
  >
    <div class="voice-ui" aria-live="polite">
      <section class="voice-ui-section" data-realtime-voice-target="summarySection">
        <h2 class="voice-ui-section__title">Summary</h2>
        <p class="voice-ui-summary" data-realtime-voice-target="summary"></p>
      </section>

      <section class="voice-ui-section" data-realtime-voice-target="recipeSection">
        <h2 class="voice-ui-section__title">Suggestion</h2>
        <div class="voice-ui-recipe" data-realtime-voice-target="recipe"></div>
      </section>

      <section class="voice-ui-section" data-realtime-voice-target="actionsSection">
        <h2 class="voice-ui-section__title">Actions</h2>
        <div class="voice-ui-actions" data-realtime-voice-target="actions"></div>
      </section>
    </div>

    <%= render "shared/voice_agent_fab", mode: :button %>

    <p class="voice-lab-status" data-realtime-voice-target="status" role="status"></p>
  </section>
</div>
