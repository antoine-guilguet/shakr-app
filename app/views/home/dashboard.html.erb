<section class="homepage-hero">
  <div class="homepage-hero-line"></div>
  <div class="homepage-hero-circle"></div>

  <div class="homepage-hero-content">
    <div class="homepage-hero-eyebrow">Signed in</div>
    <h1>
      Welcome back,<br>
      <em><%= current_user.first_name.presence || current_user.username.presence || "shaker" %></em>.
    </h1>
    <p class="homepage-hero-subtitle">
      This is your private dashboard, used here to test navigation and authentication.
      Try logging out from the navbar to confirm you are redirected to the homepage.
    </p>
  </div>
</section>

<section class="dashboard-ai">
  <div class="dashboard-ai-header">
    <div class="dashboard-ai-label">AI recipe lab</div>
    <h2 class="dashboard-ai-title">Draft a new cocktail from a prompt.</h2>
    <p class="dashboard-ai-subtitle">
      Tell Shakr what you are in the mood for — flavors, spirits, mood, constraints — and it will propose a structured recipe.
    </p>
  </div>

  <div class="dashboard-ai-grid">
    <div class="dashboard-ai-form-card">
      <%= form_with url: ai_recipes_path, scope: :ai_recipe, local: true do |f| %>
        <div class="dashboard-ai-field">
          <label class="dashboard-ai-label-small" for="ai_recipe_prompt">
            Your brief
          </label>
          <%= f.text_area :prompt,
                rows: 5,
                class: "dashboard-ai-textarea",
                placeholder: "E.g. a bright, citrusy gin sour with egg white, not too sweet, for an aperitif" %>
          <p class="dashboard-ai-help">
            Mention base spirits, flavor notes, sweetness, occasion, and any ingredients you want to use or avoid.
          </p>
        </div>

        <% if flash[:alert].present? %>
          <p class="dashboard-ai-error"><%= flash[:alert] %></p>
        <% end %>

        <div class="dashboard-ai-actions">
          <%= f.submit "Generate recipe", class: "btn-primary" %>
        </div>
      <% end %>
    </div>

    <div class="dashboard-ai-result-card">
      <% if defined?(@recipe) && @recipe.present? %>
        <%= render "recipes/ai_recipe", recipe: @recipe %>
      <% else %>
        <div class="dashboard-ai-placeholder">
          <h3>Nothing in the shaker yet.</h3>
          <p>Describe a cocktail idea on the left and your AI-generated recipe will appear here.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>

