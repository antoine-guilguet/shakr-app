<div class="recipes-index<%= " recipes-index--voice-fab" if user_signed_in? %>">
  <div class="recipes-index-header">
    <h1>Cocktails</h1>
    <div class="recipes-index-header-actions">
      <% if !mobile_device? %>
        <%= link_to "Create recipe", new_recipe_path, class: "btn-primary" %>
      <% end %>
      <div class="recipes-index-filters" role="navigation" aria-label="Filter recipes">
        <%= link_to "All", recipes_path, class: recipes_index_filter_class(@visibility_filter, "all") %>
        <%= link_to "Public", recipes_path(visibility: "public"), class: recipes_index_filter_class(@visibility_filter, "public") %>
        <%= link_to "Yours", recipes_path(visibility: "private"), class: recipes_index_filter_class(@visibility_filter, "private") %>
      </div>
    </div>
  </div>

  <% if @recipes.any? %>
    <div class="recipes-index-list">
      <% @recipes.each do |recipe| %>
        <% recipe_label = recipe.name.presence || "Untitled Cocktail" %>
        <%= link_to recipe_path(recipe),
                    class: "recipes-index-card",
                    "aria-label": "View #{recipe_label}" do %>
          <div class="recipes-index-card-top">
            <h2 class="recipes-index-title"><%= recipe_label %></h2>
          </div>

          <% if recipe.description.present? %>
            <p class="recipes-index-description"><%= recipe.description %></p>
          <% end %>

          <% if recipe.tags.present? %>
            <div class="recipes-index-tags">
              <% Array(recipe.tags).each do |tag| %>
                <span class="recipes-index-tag"><%= tag %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="recipes-index-empty">No recipes yet. Start by creating one.</p>
  <% end %>

  <% if user_signed_in? %>
    <%= render "shared/voice_agent_fab", mode: :link %>
  <% end %>
</div>
