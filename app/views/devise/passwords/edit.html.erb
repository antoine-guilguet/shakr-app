<section class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Change your password</h1>

    <%= form_for(
      resource,
      as: resource_name,
      url: password_path(resource_name),
      html: { method: :put, class: "auth-form" }
    ) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="auth-field">
        <%= f.label :password, "New password", class: "auth-label" %>

        <% if @minimum_password_length %>
          <p><em>(<%= @minimum_password_length %> characters minimum)</em></p>
        <% end %>

        <%= f.password_field :password,
              autofocus: true,
              autocomplete: "new-password",
              class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, "Confirm new password", class: "auth-label" %>
        <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "auth-input" %>
      </div>

      <div class="auth-actions">
        <%= f.submit "Change my password", class: "auth-button" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
