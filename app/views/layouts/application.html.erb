<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Shakr — Your AI Cocktail Companion" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>


    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Compiled Tailwind bundle (see Procfile.dev: bin/rails tailwindcss:watch) %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/navbar" %>
    <div class="flash-container">
      <% flash.each do |type, message| %>
        <% next if message.blank? %>
        <div class="flash <%= "flash-#{type}" %>">
          <span><%= message %></span>
        </div>
      <% end %>
    </div>

    <% if content_for?(:full_bleed) %>
      <%= yield %>
    <% else %>
      <main class="app-shell">
        <%= yield %>
      </main>
    <% end %>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const flashes = document.querySelectorAll(".flash");

        flashes.forEach((flash, index) => {
          // Staggered entrance from the right
          requestAnimationFrame(() => {
            flash.classList.add("flash--visible");
          });

          const hideAfterMs = 3000 + index * 150;

          setTimeout(() => {
            flash.classList.remove("flash--visible");

            const removeFlash = () => flash.remove();

            if (flash instanceof HTMLElement) {
              const onTransitionEnd = (event) => {
                if (event.propertyName === "opacity") {
                  flash.removeEventListener("transitionend", onTransitionEnd);
                  removeFlash();
                }
              };

              flash.addEventListener("transitionend", onTransitionEnd);
            } else {
              removeFlash();
            }
          }, hideAfterMs);
        });
      });
    </script>
  </body>
</html>
