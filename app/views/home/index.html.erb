<% content_for :full_bleed, true %>

<section class="homepage-hero">
  <div class="homepage-hero-line"></div>
  <div class="homepage-hero-circle"></div>

  <div class="homepage-hero-content">
    <div class="homepage-hero-copy">
      <div class="homepage-hero-eyebrow">AI Cocktail Companion for Bartenders</div>
      <div class="homepage-hero-lede">
        <h1>
          Voice your way up to the<br><em> perfect cocktail</em>
        </h1>
        <p class="homepage-hero-subtitle">
          Explore new recipes, find cocktails from what's in your bar, and capture every creation — all hands-free.
        </p>
      </div>
    </div>

    <div class="homepage-signup-form">
      <div class="homepage-signup-row">
        <%= link_to "Start Shaking", new_user_registration_path, class: "btn-primary" %>
      </div>
      <p class="homepage-signup-note">Free to start. No credit card required.</p>
    </div>
  </div>
</section>

<section class="homepage-features">
  <div class="homepage-features-header">
    <div class="homepage-features-label">What Shakr does</div>
  </div>
  <div class="homepage-features-grid">
    <div class="homepage-feature">
      <div class="homepage-feature-num">01</div>
      <div class="homepage-feature-title">Explore by voice</div>
      <p class="homepage-feature-desc">
        Ask your AI assistant for new recipes, flavor pairings, or spirit substitutions — without touching your phone while you work.
      </p>
    </div>
    <div class="homepage-feature">
      <div class="homepage-feature-num">02</div>
      <div class="homepage-feature-title">Bar-to-glass intelligence</div>
      <p class="homepage-feature-desc">
        Tell Shakr what's on your shelf. It finds the best cocktails you can make right now, from your existing inventory.
      </p>
    </div>
    <div class="homepage-feature">
      <div class="homepage-feature-num">03</div>
      <div class="homepage-feature-title">Your recipe book</div>
      <p class="homepage-feature-desc">
        Save, refine, and revisit your creations. Build a personal collection that grows with your craft over time.
      </p>
    </div>
  </div>
</section>

<section class="homepage-bottom-cta">
  <h2>Ready to shake things up?</h2>
  <p>Join the craft — it only takes a minute</p>
  <div class="homepage-bottom-form">
    <%= link_to "Get started", new_user_registration_path, class: "btn-primary" %>
  </div>
</section>

<footer class="homepage-footer">
  <div class="navbar-logo">Sha<span>k</span>r</div>
  <p>© 2026 Shakr. All rights reserved.</p>
</footer>