<section class="recipes-new">
  <div class="recipes-new-inner">
    <header class="recipes-new-header">
      <p class="recipes-new-label">Recipe book</p>
      <h1 class="recipes-new-title">Edit recipe</h1>
      <p class="recipes-new-subtitle">
        Update the details below. Ingredients stay one per line as
        <code class="recipes-new-code">quantity|unit|name</code>; method is one step per line.
      </p>
    </header>

    <div class="recipes-new-card">
      <%= render "form", recipe: @recipe %>
    </div>

    <div class="recipes-new-footer">
      <%= link_to "Back to recipe", @recipe %>
    </div>
  </div>
</section>
